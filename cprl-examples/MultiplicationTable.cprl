// Multiplication Table

var n : Integer;
var i : Integer;

begin

    writeln "Multiplication table!";
    write "Number: ";
    read n;
    writeln "Multiplication table for ", n;

    i := 0;
    while i <= 10 loop
        writeln n, " x ", i, " = ", n * i;
        i := i + 1;
    end loop;

end.
